{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ccsettings",
  "version": "0.1.0",
  "identifier": "com.hydai.ccsettings",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ccsettings",
        "resizable": true,
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hydai/ccsettings/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5RkNEQkE2RUYzQjg1NDMKUldSRGhUdnZwdHY4V1NYTkM0SSs0dFkvME9LS05BQjBTeUZVLy84WGhmalBYYlE1cUxCRVQvTTUK"
    }
  }
}
